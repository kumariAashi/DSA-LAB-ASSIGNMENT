     "text": [
      "10 -> 20 -> 30 -> "
     ]
    }
   ],
   "source": [
    "n1 = {\"data\": 10, \"next\": None}\n",
    "n2 = {\"data\": 20, \"next\": None}\n",
    "n3 = {\"data\": 30, \"next\": None}\n",
    "\n",
    "# Linking nodes\n",
    "n1[\"next\"] = n2\n",
    "n2[\"next\"] = n3\n",
    "\n",
    "head = n1\n",
    "\n",
    "temp = head\n",
    "while temp:\n",
    "    print(temp[\"data\"], end=\" -> \")\n",
    "    temp = temp[\"next\"]"
   ]
  }
 ],
